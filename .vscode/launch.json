{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Run Flux Extension",
      "type": "extensionHost",
      "request": "launch",
      "runtimeExecutable": "${execPath}",
      "args": [
        "--extensionDevelopmentPath=${workspaceFolder}/packages/extension"
      ],
      "outFiles": [
        "${workspaceFolder}/packages/extension/dist/**/*.js"
      ],
      "env": {
        "VSCODE_DEBUG_MODE": "true"
      }
    },
    {
      "name": "Run Flux Extension (Webview HMR)",
      "type": "extensionHost",
      "request": "launch",
      "runtimeExecutable": "${execPath}",
      "args": [
        "--extensionDevelopmentPath=${workspaceFolder}/packages/extension"
      ],
      "outFiles": [
        "${workspaceFolder}/packages/extension/dist/**/*.js"
      ],
      "env": {
        "VSCODE_DEBUG_MODE": "true",
        "AIBC_WEBVIEW_DEV": "1"
      },
      "preLaunchTask": "aibc: watch webview"
    }
  ]
}
