{
  "name": "aibc",
  "displayName": "ads by aibc - earn whilst you code",
  "description": "The #1 developer ads extension — earn whilst you code. 70% revenue share. Built by early OpenAI contributors. Native AI spinner ads in VS Code, Cursor & Claude.",
  "version": "0.1.4",
  "publisher": "AIBCMedia",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/aibcdev/aibcextensions"
  },
  "bugs": {
    "url": "https://github.com/aibcdev/aibcextensions/issues"
  },
  "qna": "https://github.com/aibcdev/aibcextensions/discussions",
  "icon": "media/icon.png",
  "engines": {
    "vscode": "^1.85.0"
  },
  "extensionKind": ["ui", "workspace"],
  "categories": ["Other"],
  "keywords": ["discover", "mcp", "ads", "earnings", "claude-code", "developer tools"],
  "homepage": "https://aibcmedia.com",
  "main": "./dist/extension.js",
  "activationEvents": ["onStartupFinished"],
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "aibc",
          "title": "AIBC Ads",
          "icon": "media/aibc.svg"
        }
      ]
    },
    "views": {
      "aibc": [
        {
          "type": "webview",
          "id": "aibc.sidebar",
          "name": "ads by aibc"
        }
      ]
    },
    "commands": [
      { "command": "aibc.signIn", "title": "aibc: Sign in" },
      { "command": "aibc.signOut", "title": "aibc: Sign out" },
      { "command": "aibc.restore", "title": "aibc: Restore Claude Code" },
      { "command": "aibc.menu", "title": "aibc: Menu" },
      { "command": "aibc.refresh", "title": "aibc: Refresh Content" },
      { "command": "aibc.openSettings", "title": "aibc: Open Settings" }
    ],
    "configuration": {
      "title": "AIBC Ads",
      "properties": {
        "aibc.apiBase": {
          "type": "string",
          "default": "https://api.aibcmedia.com",
          "description": "aibc API base URL."
        },
        "aibc.portalBase": {
          "type": "string",
          "default": "https://aibcmedia.com",
          "description": "aibc web dashboard base URL."
        },
        "aibc.feedUrl": {
          "type": "string",
          "default": "",
          "description": "Feed URL override. Empty uses apiBase/feed."
        },
        "aibc.viewThresholdSeconds": {
          "type": "number",
          "default": 5,
          "minimum": 1,
          "maximum": 600
        },
        "aibc.posthogKey": { "type": "string", "default": "" },
        "aibc.posthogHost": {
          "type": "string",
          "default": "https://us.i.posthog.com"
        },
        "aibc.analyticsEnabled": { "type": "boolean", "default": true }
      }
    }
  },
  "scripts": {
    "build": "node esbuild.mjs",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "watch": "node esbuild.mjs --watch"
  },
  "dependencies": {
    "@aibc/shared": "*",
    "posthog-node": "^4.4.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "@types/vscode": "^1.85.0",
    "esbuild": "^0.25.0",
    "typescript": "^5.7.3"
  }
}
