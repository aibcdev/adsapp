{
  "manifest_version": 3,
  "name": "ads by aibc - earn whilst you browse",
  "description": "Earn from developer ads in Chrome. 70% revenue share. Dashboard and payouts at aibcmedia.com.",
  "version": "0.1.0",
  "permissions": ["storage", "sidePanel", "tabs"],
  "host_permissions": [
    "https://aibcmedia.com/*",
    "https://www.aibcmedia.com/*",
    "https://api.aibcmedia.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "Open AIBC",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "content_scripts": [
    {
      "matches": [
        "https://aibcmedia.com/*",
        "https://www.aibcmedia.com/*"
      ],
      "js": ["bridge.js"],
      "run_at": "document_start"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
