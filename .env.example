# aibc production environment
# Copy to .env and fill in values, then deploy.

# --- API (required for production) ---
AIBC_PUBLIC_URL=https://api.aibcmedia.com
AIBC_PORTAL_URL=https://aibcmedia.com
PORT=8787
AIBC_DB_PATH=/data/aibc.db

# Google OAuth (required unless dev bypass)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Stripe (required for advertiser deposits)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# CORS (comma-separated)
AIBC_CORS_ORIGINS=https://aibcmedia.com,https://www.aibcmedia.com

# Analytics (optional)
AIBC_POSTHOG_KEY=
AIBC_POSTHOG_HOST=https://us.i.posthog.com

# --- Portal build (Vercel / CI) ---
VITE_AIBC_API=https://api.aibcmedia.com

# --- Local dev only ---
# AIBC_DEV_BYPASS=1
