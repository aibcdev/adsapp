# aibc production environment
# Copy to .env for local dev:  cp .env.example .env
# Full guide: ENV.md

# --- Local dev ---
AIBC_DEV_BYPASS=1
AIBC_PUBLIC_URL=http://127.0.0.1:8787
AIBC_PORTAL_URL=http://localhost:5175
VITE_AIBC_API=http://127.0.0.1:8787

# --- API production (Fly secrets) ---
# AIBC_PUBLIC_URL=https://api.aibcmedia.com
# AIBC_PORTAL_URL=https://aibcmedia.com
# PORT=8787
# AIBC_DB_PATH=/data/aibc.db
# AIBC_CORS_ORIGINS=https://aibcmedia.com,https://www.aibcmedia.com

# Google OAuth — https://console.cloud.google.com/
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Stripe — dashboard.stripe.com (AIBC / watchaibc@gmail.com)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
# Full live secret (sk_live_*) — required for live webhooks. NOT the CLI rk_live key.
# Run: npm run stripe:fix-live
STRIPE_LIVE_SECRET_KEY=

# Analytics (optional)
AIBC_POSTHOG_KEY=
AIBC_POSTHOG_HOST=https://us.i.posthog.com

# --- Netlify (site env vars in dashboard, not this file) ---
# VITE_AIBC_API=https://api.aibcmedia.com
