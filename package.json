{
  "name": "aibc-monorepo",
  "private": true,
  "version": "0.1.0",
  "workspaces": [
    "packages/shared",
    "packages/extension",
    "packages/webview",
    "packages/api",
    "packages/portal",
    "packages/cli"
  ],
  "scripts": {
    "build": "node scripts/build.mjs",
    "watch": "node scripts/build.mjs --watch",
    "dev:api": "npm run dev --workspace=@aibc/api",
    "dev:portal": "npm run dev --workspace=@aibc/portal",
    "dev:webview": "npm run dev --workspace=@aibc/webview",
    "dev": "npm run dev:api",
    "dev:stripe": "bash scripts/stripe-listen.sh",
    "stripe:sync": "bash scripts/sync-stripe-env.sh",
    "stripe:fix-live": "bash scripts/stripe-fix-live.sh",
    "deploy:api": "bash scripts/deploy-digitalocean.sh",
    "deploy:do": "bash scripts/deploy-digitalocean.sh",
    "sync:kickbacks": "node scripts/sync-kickbacks-issues.mjs",
    "package": "node scripts/package-vsix.mjs",
    "package:chrome": "bash scripts/package-chrome-extension.sh",
    "publish:marketplace": "node scripts/publish-marketplace.mjs",
    "publish:openvsx": "node scripts/publish-openvsx.mjs",
    "publish:all": "npm run publish:marketplace && npm run publish:openvsx",
    "create:partner": "node scripts/create-advertiser-partner.mjs",
    "typecheck": "npm run typecheck --workspaces --if-present"
  },
  "devDependencies": {
    "@vscode/vsce": "^3.2.1",
    "esbuild": "^0.25.0",
    "ovsx": "^0.10.2",
    "typescript": "^5.7.3"
  }
}
